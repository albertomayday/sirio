# Vercel Postgres
POSTGRES_PRISMA_URL="postgresql://user:password@host/sirio"
POSTGRES_URL_NON_POOLING="postgresql://user:password@host/sirio"

# Application
NEXT_PUBLIC_API_URL="https://sirio-tpv.vercel.app/api"
NODE_ENV="production"

# API Keys
API_KEY="your-api-key-here"
JWT_SECRET="your-jwt-secret-here"

# Database
DATABASE_NAME="sirio"
DATABASE_USER="postgres"

# Features
DEBUG="false"
LOG_LEVEL="info"

# CORS
CORS_ORIGIN="https://sirio-tpv.vercel.app"

# AEAT Integration
AEAT_API_URL="https://www.agenciatributaria.es/wlpl/SIRIO"
AEAT_API_KEY=""

# Email (optional)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
